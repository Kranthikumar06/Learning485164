extends layout

block content
  .profile-container
    div(style="flex:1;")
      .profile-title Edit Profile
      form(action="/users/edit-profile", method="POST", enctype="multipart/form-data", style="max-width:400px;margin:auto;")
        .profile-fields
          .profile-field
            label(for="name") User Name
            input(type="text", name="name", id="name", value=name, required)
          .profile-field
            label(for="email") E-mail
            input(type="email", name="email", id="email", value=email, readonly)
          .profile-field
            label(for="location") Location
            input(type="text", name="location", id="location", value=location)
          .profile-field
            label(for="phone") Phone
            input(type="text", name="phone", id="phone", value=phone)
          .profile-field
            label(for="photo") Profile Photo
            input(type="file", name="photo", id="photo", accept="image/*")
        .profile-actions
          button(type="submit", class="edit") Save Changes
          button(type="button", class="cancel", onclick="window.location.href='/profile'") Cancel
    .profile-image-section
      if user && user.photo
        img(src=user.photo, alt="Profile Photo", style="width:120px;height:120px;border-radius:50%;")
      else
        img(src="/images/profile.png", alt="Campus Logo", style="width:120px;height:120px;border-radius:50%;")
  footer
    p © 2025 Secure My Campus | 
      a(href="#") Privacy Policy
      |  
      a(href="#") Help Center

.profile-actions .edit {
  min-width: 400px;
  padding: 16px 120px;
  font-size: 22px;
}
