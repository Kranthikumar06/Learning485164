extends layout

block content
  .navbar
    .logo-container
      img(src="/images/Campus.png", alt="Secure My Campus Logo")
      div
        span(style="font-size:22px;font-weight:bold;color:#007bff;") Secure
        span(style="font-size:16px;color:#333;letter-spacing:1px;") My Campus
    .nav-links
      a(href="/") Home
      a(href="/complaint") Complaint Box
        if email
          a(href="/form") Form Page
          a(href="/help") Help Center
        else
          a(href="/users/signup") Sign Up
          a(href="/users/signin") Sign In
    .profile-top-right
      if email
        a(href="/profile", title="Profile")
          if user && user.photo && user.photo !== '' && user.photo !== null
              img(src=user.photo, alt="Profile Photo", style="width:40px;height:40px;border-radius:50%;background:#eee;", onerror="this.onerror=null;this.src='/images/profile.png';")
          else
            img(src="/images/profile.png", alt="Profile", style="width:40px;height:40px;border-radius:50%;background:#eee;")
  if typeof user !== 'undefined' && user && user.name
    .welcome-user(style="margin:16px 0;font-weight:bold;color:#1976d2;") Welcome, #{user.name}!
  .home-bg-section
    .home-bg-overlay
      p.home-welcome Welcome to Secure My Campus!
      p.home-desc
        | Secure My Campus is a platform designed to help students, staff, and visitors easily submit complaints, access forms, manage profiles, and sign in securely. Our goal is to make your campus experience safer, more efficient, and more connected. If you have any issues or suggestions, please reach out to us!
  .home-contact
    h2 Contact Us
    p Phone: +91-9876543210
    p Email: contact@securemycampus.com
footer
  p
    | © 2025 Secure My Campus |
    a(href="#") Privacy Policy
